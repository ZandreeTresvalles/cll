# Server environment variables
# Copy this to .env for local development, or set these in Render dashboard for production.
# NEVER commit the real .env file — it contains secrets.

# Node environment
NODE_ENV=production

# Port (Render sets this automatically; default 5000 for local)
PORT=5000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL  →  Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Service role key (KEEP SECRET — never put in client code)
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Lazada API ────────────────────────────────────────────────────────────────
# App key from Lazada Open Platform developer console
LAZADA_APP_KEY=your-lazada-app-key

# App secret from Lazada Open Platform developer console
LAZADA_APP_SECRET=your-lazada-app-secret

# Regional API base URL — pick the correct one for your market:
#   Philippines : https://api.lazada.com.ph/rest
#   Singapore   : https://api.lazada.sg/rest
#   Malaysia    : https://api.lazada.com.my/rest
#   Thailand    : https://api.lazada.co.th/rest
#   Vietnam     : https://api.lazada.vn/rest
#   Indonesia   : https://api.lazada.co.id/rest
LAZADA_API_URL=https://api.lazada.com.ph/rest

# ── CORS (optional) ──────────────────────────────────────────────────────────
# If you deploy the frontend on Render too, set its URL here so CORS allows it.
# Example: https://cll-frontend.onrender.com
FRONTEND_URL=
